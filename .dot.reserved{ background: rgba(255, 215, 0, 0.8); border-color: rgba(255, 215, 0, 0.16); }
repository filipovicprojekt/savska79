        orientation: "Sjever – Jug – Zapad",
        floorplan: "k1s3.png",
        descriptionHTML: `
          <p><b>Stan se sastoji od:</b></p>
          <ul class="list">
            <li>dnevnog boravka s kuhinjom i blagovaonicom</li>
            <li>dvije spavaće sobe</li>
            <li>dvije kupaonice s WC-om</li>
            <li>dva hodnika</li>
            <li>krovne terase</li>
            <li>vanjskog parkirnog mjesta (priprema za EV punjač)</li>
          </ul>
        `,
        prices: { cash: 196000, credit: 210000, parking: 8000, totalCash: 204000, totalCredit: 218000 },
        priceNote: "CIJENA NAKON DOVRŠETKA GRADNJE RASTE!"
      },
      K2S2: {
        title: "K2S2 – Stan 1. kat",
        area: "95 m²",
        orientation: "Sjever – Jug – Istok",
        floorplan: "k2s2.png",
        descriptionHTML: `
          <p><b>Stan se sastoji od:</b></p>
          <ul class="list">
            <li>dnevnog boravka s kuhinjom i blagovaonicom</li>
            <li>tri spavaće sobe</li>
            <li>dvije kupaonice s WC-om</li>
            <li>izbe</li>
            <li>dva hodnika</li>
            <li>terase i lođe</li>
            <li>vanjskog parkirnog mjesta (priprema za EV punjač)</li>
          </ul>
        `,
        prices: { cash: 266000, credit: 285000, parking: 8000, totalCash: 274000, totalCredit: 293000 },
        priceNote: "CIJENA NAKON DOVRŠETKA GRADNJE RASTE!"
      },
      K2S3: {
        title: "K2S3 – Penthouse",
        area: "70 m²",
        orientation: "Sjever – Jug – Istok",
        floorplan: "k2s3.png",
        descriptionHTML: `
          <p><b>Stan se sastoji od:</b></p>
          <ul class="list">
            <li>dnevnog boravka s kuhinjom i blagovaonicom</li>
            <li>dvije spavaće sobe</li>
            <li>dvije kupaonice s WC-om</li>
            <li>dva hodnika</li>
            <li>krovne terase</li>
            <li>vanjskog parkirnog mjesta (priprema za EV punjač)</li>
          </ul>
        `,
        prices: { cash: 196000, credit: 210000, parking: 8000, totalCash: 204000, totalCredit: 218000 },
        priceNote: "CIJENA NAKON DOVRŠETKA GRADNJE RASTE!"
      }
    };

    const eur = (n) => new Intl.NumberFormat('hr-HR', { style:'currency', currency:'EUR', maximumFractionDigits:0 }).format(n);

    function labelForStatus(st){
      if(st === "sold") return "Prodano";
      if(st === "reserved") return "Rezervirano";
      return "Dostupno";
    }

    // Apply availability to overlays + select
    const stanSelect = document.getElementById('stanSelect');
    function applyAvailability(){
      document.querySelectorAll('.unit').forEach(el=>{
        const id = el.dataset.unit;
        const st = availability[id] || "available";
        el.classList.remove('sold','reserved');

        if(st === "sold") el.classList.add('sold');
        if(st === "reserved") el.classList.add('reserved');

        const rib = el.querySelector('.ribbon');
        if(st === "sold" || st === "reserved"){
          if(!rib){
            const r = document.createElement('span');
            r.className = 'ribbon';
            r.textContent = (st === "sold") ? "PRODANO" : "REZERVIRANO";
            el.appendChild(r);
          } else {
            rib.textContent = (st === "sold") ? "PRODANO" : "REZERVIRANO";
          }
        } else {
          if(rib) rib.remove();
        }
      });

      Array.from(stanSelect.options).forEach(opt=>{
        const id = opt.value;
        if(!id) return;
        const st = availability[id] || "available";
        opt.disabled = (st === "sold");
        opt.textContent = (st === "sold") ? `${id} – PRODANO` : id;
      });
    }

    // Details modal
    const detailBack = document.getElementById('detailBack');
    const detailClose = document.getElementById('detailClose');
    const detailTitle = document.getElementById('detailTitle');
    const detailMeta = document.getElementById('detailMeta');
    const detailText = document.getElementById('detailText');
    const statusBadge = document.getElementById('statusBadge');
    const areaBadge = document.getElementById('areaBadge');
    const priceTableWrap = document.getElementById('priceTableWrap');
    const priceNote = document.getElementById('priceNote');
    const floorplanWrap = document.getElementById('floorplanWrap');
    const openPlanBtn = document.getElementById('openPlanBtn');

    let currentPlan = null;
    let currentPlanTitle = null;

    function buildPriceTable(prices){
      const gardenRows = (prices.gardenCash || prices.gardenCredit) ? `
        <tr><td>Vrt (gotovina)</td><td>${prices.gardenCash ? eur(prices.gardenCash) : "—"}</td></tr>
        <tr><td>Vrt (kredit)</td><td>${prices.gardenCredit ? eur(prices.gardenCredit) : "—"}</td></tr>
      ` : "";

      return `
        <table>
          <thead><tr><th>Stavka</th><th>Iznos</th></tr></thead>
          <tbody>
            <tr><td>Cijena stana (gotovina)</td><td><b>${eur(prices.cash)}</b></td></tr>
            <tr><td>Cijena stana (kredit)</td><td><b>${eur(prices.credit)}</b></td></tr>
            ${gardenRows}
            <tr><td>Parkirno mjesto</td><td>${eur(prices.parking)}</td></tr>
            <tr><td><b>Ukupno (gotovina)</b></td><td><b>${eur(prices.totalCash)}</b></td></tr>
            <tr><td><b>Ukupno (kredit)</b></td><td><b>${eur(prices.totalCredit)}</b></td></tr>
          </tbody>
        </table>
      `;
    }

    function openDetails(unitId){
      const st = availability[unitId] || "available";
      if(st === "sold"){
        showToast(`${unitId} je PRODANO i zaključano.`);
        return;
      }
      const data = units[unitId];
      if(!data){ showToast("Nema podataka za ovaj stan."); return; }

      detailTitle.textContent = data.title;
      detailMeta.textContent = `${data.area || "—"} • Orijentacija: ${data.orientation || "—"}`;

      statusBadge.textContent = labelForStatus(st);
      statusBadge.classList.toggle('sold', st === 'sold');
      areaBadge.textContent = data.area || "—";
      detailText.innerHTML = data.descriptionHTML || "";

      if(data.prices){
        priceTableWrap.innerHTML = buildPriceTable(data.prices);
        priceNote.textContent = data.priceNote || "";
        priceNote.style.display = data.priceNote ? "block" : "none";
      } else {
        priceTableWrap.innerHTML = `<p style="color:var(--muted); margin:0;">Cijene nisu dostupne.</p>`;
        priceNote.style.display = "none";
      }

      if(data.floorplan){
        currentPlan = data.floorplan;
        currentPlanTitle = `Tlocrt – ${unitId}`;
        floorplanWrap.innerHTML = `<img class="thumb" src="${data.floorplan}" alt="Tlocrt ${unitId}">`;
        openPlanBtn.disabled = false;
        openPlanBtn.style.opacity = "1";
      } else {
        currentPlan = null;
        currentPlanTitle = null;
        floorplanWrap.innerHTML = `<div style="color:var(--muted); font-size:14px;">Tlocrt nije dostupan.</div>`;
        openPlanBtn.disabled = true;
        openPlanBtn.style.opacity = ".6";
      }

      stanSelect.value = unitId;
      detailBack.classList.add('open');
    }

    function closeDetails(){ detailBack.classList.remove('open'); }

    detailClose.addEventListener('click', closeDetails);
    detailBack.addEventListener('click', (e)=>{ if(e.target === detailBack) closeDetails(); });

    openPlanBtn.addEventListener('click', ()=>{
      if(currentPlan) openViewer(currentPlan, currentPlanTitle);
    });

    // Viewer
    const viewerBack = document.getElementById('viewerBack');
    const viewerTitle = document.getElementById('viewerTitle');
    const stage = document.getElementById('stage');
    const stageImg = document.getElementById('stageImg');
    const zoomInBtn = document.getElementById('zoomIn');
    const zoomOutBtn = document.getElementById('zoomOut');
    const viewerCloseBtn = document.getElementById('viewerClose');

    let v = { scale: 1, x: 0, y: 0, dragging:false, px:0, py:0 };
    function applyTransform(){
      stageImg.style.transform = `translate(calc(-50% + ${v.x}px), calc(-50% + ${v.y}px)) scale(${v.scale})`;
    }
    function openViewer(src, title){
      viewerTitle.textContent = title || "Tlocrt";

      v = { scale: 1, x: 0, y: 0, dragging:false, px:0, py:0 };
      applyTransform();

      stageImg.onload = ()=>{
        const sw = stage.clientWidth || 1;
        const sh = stage.clientHeight || 1;
        const iw = stageImg.naturalWidth || 1;
        const ih = stageImg.naturalHeight || 1;
        const fit = Math.min(sw / iw, sh / ih) * 0.98;
        v.scale = Math.min(6, Math.max(0.2, fit));
        v.x = 0; v.y = 0;
        applyTransform();
      };

      stageImg.src = src;
      viewerBack.classList.add('open');
    }
    function closeViewer(){ viewerBack.classList.remove('open'); stageImg.src = ""; }
    function zoom(delta){ v.scale = Math.min(6, Math.max(0.2, v.scale + delta)); applyTransform(); }

    zoomInBtn.addEventListener('click', ()=>zoom(0.2));
    zoomOutBtn.addEventListener('click', ()=>zoom(-0.2));
    viewerCloseBtn.addEventListener('click', closeViewer);
    viewerBack.addEventListener('click', (e)=>{ if(e.target === viewerBack) closeViewer(); });

    function startDrag(x,y){ v.dragging=true; v.px=x; v.py=y; }
    function moveDrag(x,y){
      if(!v.dragging) return;
      const dx=x - v.px, dy=y - v.py;
      v.px=x; v.py=y;
      v.x += dx; v.y += dy;
      applyTransform();
    }
    function endDrag(){ v.dragging=false; }

    stage.addEventListener('mousedown', (e)=> startDrag(e.clientX, e.clientY));
    window.addEventListener('mousemove', (e)=> moveDrag(e.clientX, e.clientY));
    window.addEventListener('mouseup', endDrag);

    // Touch gestures
    let pinch = { active:false, startDist:0, startScale:1, startMidX:0, startMidY:0, startX:0, startY:0 };
    function dist(a,b){
      const dx = a.clientX - b.clientX;
      const dy = a.clientY - b.clientY;
      return Math.hypot(dx, dy);
    }
    function mid(a,b){
      return { x: (a.clientX + b.clientX)/2, y: (a.clientY + b.clientY)/2 };
    }

    stage.addEventListener('touchstart', (e)=>{
      if(e.touches.length === 1){
        const t = e.touches[0];
        pinch.active = false;
        startDrag(t.clientX, t.clientY);
      } else if(e.touches.length === 2){
        e.preventDefault();
        const a = e.touches[0], b = e.touches[1];
        const m = mid(a,b);
        pinch = {
          active:true,
          startDist: dist(a,b),
          startScale: v.scale,
          startMidX: m.x,
          startMidY: m.y,
          startX: v.x,
          startY: v.y
        };
        v.dragging = false;
      }
    }, {passive:false});

    stage.addEventListener('touchmove', (e)=>{
      if(e.touches.length === 1 && !pinch.active){
        const t = e.touches[0];
        moveDrag(t.clientX, t.clientY);
        return;
      }
      if(e.touches.length === 2){
        e.preventDefault();
        const a = e.touches[0], b = e.touches[1];
        const m = mid(a,b);
        const d = dist(a,b);

        const rawScale = pinch.startScale * (d / Math.max(10, pinch.startDist));
        v.scale = Math.min(6, Math.max(0.2, rawScale));

        v.x = pinch.startX + (m.x - pinch.startMidX);
        v.y = pinch.startY + (m.y - pinch.startMidY);

        applyTransform();
      }
    }, {passive:false});

    stage.addEventListener('touchend', (e)=>{
      if(e.touches.length === 0){
        pinch.active = false;
        endDrag();
      }
      if(e.touches.length === 1){
        pinch.active = false;
        const t = e.touches[0];
        startDrag(t.clientX, t.clientY);
      }
    }, {passive:false});

    stage.addEventListener('wheel', (e)=>{
      e.preventDefault();
      zoom(e.deltaY < 0 ? 0.12 : -0.12);
    }, {passive:false});

    // Unit click
    document.querySelectorAll('.unit').forEach(el=>{
      el.addEventListener('click', (e)=>{
        e.preventDefault();
        openDetails(el.dataset.unit);
      });
    });

    // Gallery lightbox + swipe
    const lb = document.getElementById('lightbox');
    const lbImg = document.getElementById('lbImg');
    const lbTitle = document.getElementById('lbTitle');
    const lbPrev = document.getElementById('lbPrev');
    const lbNext = document.getElementById('lbNext');
    const lbClose = document.getElementById('lbClose');
    const galleryItems = Array.from(document.querySelectorAll('.galleryItem'));
    const gallery = galleryItems.map(el => ({ src: el.dataset.src, title: el.dataset.title }));
    let gi = 0;

    function openLB(index){
      gi = index;
      lbImg.src = gallery[gi].src;
      lbTitle.textContent = gallery[gi].title || "Galerija";
      lb.classList.add('open');
      lb.setAttribute('aria-hidden','false');
    }
    function closeLB(){
      lb.classList.remove('open');
      lb.setAttribute('aria-hidden','true');
      lbImg.src = '';
    }
    function showIndex(i){
      gi = (i + gallery.length) % gallery.length;
      lbImg.src = gallery[gi].src;
      lbTitle.textContent = gallery[gi].title || "Galerija";
    }

    galleryItems.forEach((el, idx)=> el.addEventListener('click', ()=> openLB(idx)));
    lbPrev.addEventListener('click', ()=> showIndex(gi - 1));
    lbNext.addEventListener('click', ()=> showIndex(gi + 1));
    lbClose.addEventListener('click', closeLB);
    lb.addEventListener('click', (e)=>{ if(e.target === lb) closeLB(); });

    let sx=0, sy=0;
    document.getElementById('lbStage').addEventListener('touchstart', (e)=>{
      const t=e.touches[0]; sx=t.clientX; sy=t.clientY;
    }, {passive:true});
    document.getElementById('lbStage').addEventListener('touchend', (e)=>{
      const t=e.changedTouches[0];
      const dx=t.clientX - sx;
      const dy=t.clientY - sy;
      if(Math.abs(dx) > 50 && Math.abs(dy) < 60){
        if(dx < 0) showIndex(gi + 1);
        else showIndex(gi - 1);
      }
    }, {passive:true});

    // ESC close all
    document.addEventListener('keydown', (e)=>{
      if(e.key === "Escape"){
        closeDetails();
        closeViewer();
        closeLB();
        closeDrawer();
      }
    });

    // init
    applyAvailability();

    // Cookie consent
    const CONSENT_KEY = "fp_cookie_consent_v1";
    const cookieBanner = document.getElementById("cookieBanner");
    const cookieAccept = document.getElementById("cookieAccept");
    const cookieReject = document.getElementById("cookieReject");
    const openCookieSettings = document.getElementById("openCookieSettings");

    function getConsent(){ return localStorage.getItem(CONSENT_KEY); }
    function setConsent(v){ localStorage.setItem(CONSENT_KEY, v); }
    function showBanner(){ cookieBanner.classList.add('open'); }
    function hideBanner(){ cookieBanner.classList.remove('open'); }

    const GA_MEASUREMENT_ID = "G-XXXXXXXXXX";
    function loadGA(){
      if(!GA_MEASUREMENT_ID || GA_MEASUREMENT_ID === "G-XXXXXXXXXX") return;
      if(window.__gaLoaded) return;
      window.__gaLoaded = true;

      const s = document.createElement("script");
      s.async = true;
      s.src = "https://www.googletagmanager.com/gtag/js?id=" + encodeURIComponent(GA_MEASUREMENT_ID);
      document.head.appendChild(s);

      window.dataLayer = window.dataLayer || [];
      function gtag(){ window.dataLayer.push(arguments); }
      window.gtag = gtag;

      gtag("js", new Date());
      gtag("config", GA_MEASUREMENT_ID, {
        anonymize_ip: true,
        allow_google_signals: false,
        allow_ad_personalization_signals: false
      });
    }

    function initConsent(){
      const c = getConsent();
      if(c === "accepted"){ hideBanner(); loadGA(); return; }
      if(c === "rejected"){ hideBanner(); return; }
      showBanner();
    }

    cookieAccept.addEventListener('click', ()=>{ setConsent("accepted"); hideBanner(); loadGA(); });
    cookieReject.addEventListener('click', ()=>{ setConsent("rejected"); hideBanner(); });

    openCookieSettings.addEventListener('click', (e)=>{
      e.preventDefault();
      showBanner();
    });

    initConsent();

    // Basic: prevent right-click / drag on images (nije 100% moguće spriječiti)
    document.addEventListener('contextmenu', (e)=>{
      if(e.target && (e.target.tagName === 'IMG' || e.target.closest('.galleryItem') || e.target.closest('.lbPanel') || e.target.closest('.viewer'))) {
        e.preventDefault();
      }
    });
    document.querySelectorAll('img').forEach(img=>{
      img.setAttribute('draggable', 'false');
    });
  </script>
</body>
