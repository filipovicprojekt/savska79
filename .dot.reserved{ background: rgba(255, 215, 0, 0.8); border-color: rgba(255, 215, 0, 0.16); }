<!doctype html>
<html lang="hr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

  <title>SAVSKA 79 RESIDENCE – Filipović Projekt</title>
  <meta name="description" content="Kvalitetna moderna novogradnja u Jelkovcu (Sesvete). Pregled stanova, galerija i upit." />
  <meta name="robots" content="index,follow" />
  <link rel="canonical" href="https://example.com/" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content="SAVSKA 79 RESIDENCE – Filipović Projekt" />
  <meta property="og:description" content="Kvalitetna moderna novogradnja u Jelkovcu (Sesvete). Pregled stanova, galerija i upit." />
  <meta property="og:image" content="naslovna.png" />
  <meta property="og:locale" content="hr_HR" />

  <style>
    :root{
      --bg:#f6f7fb;
      --card:#ffffff;
      --text:#121826;
      --muted:#5b6476;
      --border:#e6e8ef;

      --accent:#8b6b4c;
      --accent2:#6f533a;

      --danger:#b42318;
      --danger2:#d92d20;

      --shadow: 0 14px 40px rgba(16,24,40,.10);
      --radius:16px;

      --overlay: rgba(0,0,0,.16);
      --overlayHover: rgba(0,0,0,.26);

      --soldOverlay: rgba(140,0,0,.22);
      --soldOverlayHover: rgba(140,0,0,.34);

      --reserveOverlay: rgba(140,0,0,.16);
      --reserveOverlayHover: rgba(140,0,0,.24);
    }

    *{ box-sizing:border-box; }
    html{ scroll-behavior:smooth; }
    body{
      margin:0;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      color: var(--text);
      line-height: 1.6;
      background: var(--bg);
    }
    a{ color: inherit; }
    .container{
      width:min(1100px, 100%);
      margin: 0 auto;
      padding: 0 14px;
    }

    /* basic anti-download */
    img{ -webkit-user-drag:none; user-select:none; }

    /* TOPBAR */
    .topbar{
      position: sticky;
      top:0;
      z-index: 50;
      background: rgba(246,247,251,.92);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }
    .topbarInner{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding: 10px 0;
    }
    .brand{
      display:flex;
      align-items:center;
      gap:10px;
      min-width: 0;
    }
    .logo{
      width: 44px;
      height: 44px;
      border-radius: 12px;
      object-fit: contain;
      background: #fff;
      border: 1px solid var(--border);
      box-shadow: 0 10px 22px rgba(16,24,40,.06);
      padding: 6px;
      flex: 0 0 auto;
    }
    .brandText{
      min-width:0;
      display:flex;
      flex-direction:column;
      gap:2px;
    }
    .brandText b{
      font-size: 13px;
      letter-spacing:-.01em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .brandText span{
      font-size: 12px;
      color: var(--muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .menuBtn{
      width:44px;height:44px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background:#fff;
      box-shadow: 0 10px 22px rgba(16,24,40,.06);
      cursor:pointer;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      font-size: 18px;
      font-weight: 900;
    }

    /* Drawer */
    .drawerBack{
      position: fixed;
      inset:0;
      background: rgba(16,24,40,.42);
      display:none;
      z-index: 80;
    }
    .drawerBack.open{ display:block; }
    .drawer{
      position: fixed;
      top:0; right:0;
      width: min(92vw, 340px);
      height: 100vh;
      background: rgba(255,255,255,.98);
      border-left: 1px solid var(--border);
      box-shadow: -20px 0 60px rgba(0,0,0,.18);
      padding: 14px;
      transform: translateX(110%);
      transition: transform .2s ease;
    }
    .drawerBack.open .drawer{ transform: translateX(0); }
    .drawerTop{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      margin-bottom: 10px;
    }
    .drawerTop b{ font-size: 14px; }
    .drawer a{
      display:block;
      padding: 12px 10px;
      border-radius: 14px;
      text-decoration:none;
      color: var(--text);
      font-weight: 900;
      border: 1px solid rgba(0,0,0,.06);
      background: rgba(246,247,251,.7);
      margin: 8px 0;
    }

    /* Sections */
    section{ padding: 38px 0; }
    .sectionTitle{
      margin:0 0 10px;
      font-size: 22px;
      letter-spacing: -0.02em;
      text-align:center;
    }
    .sectionSub{
      margin: 0 auto 18px;
      color: var(--muted);
      font-size: 13px;
      text-align:center;
      max-width: 900px;
    }

    /* NEW: uočljiv tekst za odabir stana */
    .stanNotice{
      margin: 0 auto 18px;
      text-align:center;
      font-weight: 1000;
      letter-spacing: -.02em;
      color: var(--text);
      background: rgba(139,107,76,.10);
      border: 1px solid rgba(139,107,76,.20);
      border-radius: 16px;
      padding: 12px 12px;
      box-shadow: 0 12px 28px rgba(16,24,40,.08);
      max-width: 900px;
      font-size: 15px;
    }
    @media (max-width: 720px){
      .stanNotice{
        font-size: 16px;
        padding: 14px 12px;
      }
    }
    @media (min-width: 960px){
      .stanNotice{
        font-size: 16px;
      }
    }

    /* Intro */
    .intro{ padding: 18px 0 6px; }
    .introCard{
      background: rgba(255,255,255,.92);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: 0 14px 40px rgba(16,24,40,.10);
      padding: 14px;
    }
    .introTitle{
      margin:0;
      font-size: 22px;
      letter-spacing: -0.03em;
      text-transform: uppercase;
      text-align:left;
    }
    .introSubtitle{
      margin: 8px 0 0;
      color: var(--muted);
      font-size: 13px;
      font-weight: 900;
    }

    .heroImage{
      margin-top: 12px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      box-shadow: 0 14px 40px rgba(16,24,40,.10);
      overflow:hidden;
      background:#fff;
    }
    .heroImage img{
      width:100%;
      height:auto;
      display:block;
      object-fit: cover;
    }

    .card{
      background: rgba(255,255,255,.95);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: 0 10px 26px rgba(16,24,40,.06);
      overflow:hidden;
    }
    .cardHead{
      padding: 12px 12px 10px;
      border-bottom: 1px solid var(--border);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
    }
    .cardHead h3{
      margin:0;
      font-size: 14px;
      font-weight: 950;
      letter-spacing: -.01em;
    }
    .cardBody{ padding: 14px; }

    .grid{
      display:grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }

    /* Inline "Pročitaj više" */
    .jelPreview p{ margin: 0 0 10px; }
    .jelMore{
      display:none;
      margin-top: 10px;
      color: var(--muted);
      font-size: inherit;
      line-height: inherit;
    }
    .jelWrap.open .jelMore{ display:block; }

    .btnRow{
      display:flex;
      gap: 10px;
      flex-wrap:wrap;
      margin-top: 10px;
    }
    .btnPrimary{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding: 12px 14px;
      background: var(--accent);
      color: #fff;
      border-radius: 14px;
      border: 1px solid rgba(0,0,0,.08);
      box-shadow: 0 14px 26px rgba(139,107,76,.22);
      font-weight: 950;
      cursor:pointer;
      text-decoration:none;
    }
    .btnPrimary:hover{ background: var(--accent2); }
    .btnGhost{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding: 12px 14px;
      background: rgba(255,255,255,.95);
      color: var(--text);
      border-radius: 14px;
      border: 1px solid var(--border);
      box-shadow: 0 10px 22px rgba(16,24,40,.06);
      font-weight: 950;
      cursor:pointer;
      text-decoration:none;
    }

    ul.list{
      margin: 0;
      padding-left: 18px;
      color: var(--muted);
      font-size: 14px;
    }
    ul.list li{ margin: 7px 0; }

    .noteDanger{
      padding: 10px 12px;
      border-radius: 14px;
      border: 1px solid rgba(217,45,32,.22);
      background: rgba(217,45,32,.06);
      color:#7a1b14;
      font-weight: 950;
    }

    /* Apartments selection */
    .legend{
      display:flex;
      gap:8px;
      justify-content:center;
      flex-wrap:wrap;
      margin-bottom: 10px;
      color: var(--muted);
      font-size: 12px;
    }
    .chip{
      display:inline-flex; align-items:center;
      gap:8px;
      padding:8px 10px;
      background: rgba(255,255,255,.85);
      border:1px solid var(--border);
      border-radius: 999px;
      box-shadow: 0 8px 20px rgba(16,24,40,.06);
      backdrop-filter: blur(6px);
    }
    .dot{ width:10px;height:10px;border-radius:50%; display:inline-block; background: rgba(0,0,0,.22); border:1px solid rgba(0,0,0,.08); }
    .dot.sold{ background: rgba(140,0,0,.38); border-color: rgba(140,0,0,.20); }
    .dot.reserved{ background: rgba(140,0,0,.22); border-color: rgba(140,0,0,.16); }
}

    .heroCard{
      background: rgba(255,255,255,.95);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: 0 14px 40px rgba(16,24,40,.10);
      overflow:hidden;
    }
    .building{
      position:relative;
      width:100%;
      aspect-ratio: 2048 / 1365;
      background: url("naslovna.png") center/cover no-repeat;
    }

    .unit{
      position:absolute;
      background: var(--overlay);
      transition: background .2s ease;
      cursor:pointer;
      display:block;
      text-decoration:none;
      outline:none;
      overflow:hidden;
    }
    .unit:hover{ background: var(--overlayHover); }
    .unit.sold{ background: var(--soldOverlay); cursor: not-allowed; }
    .unit.sold:hover{ background: var(--soldOverlayHover); }
    .unit.reserved{ background: var(--reserveOverlay); }
    .unit.reserved:hover{ background: var(--reserveOverlayHover); }

    .tag{
      position:absolute;
      top: 8px;
      padding: 4px 7px;
      font-size: 11px;
      font-weight: 950;
      letter-spacing: .02em;
      background: rgba(255,255,255,.82);
      color: #101828;
      border: 1px solid rgba(16,24,40,.10);
      border-radius: 999px;
      user-select:none;
      pointer-events:none;
      max-width: 70px;
      text-align:center;
      white-space: nowrap;
    }
    .tag.left{ left: 8px; }
    .tag.right{ right: 8px; }

    .ribbon{
      position:absolute;
      top: 10px;
      right: -34px;
      background: linear-gradient(135deg, var(--danger2), var(--danger));
      color:#fff;
      font-weight:950;
      font-size: 10px;
      letter-spacing: .08em;
      padding: 7px 44px;
      transform: rotate(35deg);
      box-shadow: 0 10px 24px rgba(180,35,24,.20);
      border: 1px solid rgba(255,255,255,.25);
      user-select:none;
      pointer-events:none;
      text-transform: uppercase;
    }

    .k1s3{ left: 0%;  top: 25.64%; width: 50%; height: 17.75%; }
    .k1s2{ left: 0%;  top: 43.39%; width: 50%; height: 17.75%; }
    .k1s1{ left: 0%;  top: 61.15%; width: 50%; height: 17.75%; }
    .k2s3{ left: 50%; top: 25.64%; width: 50%; height: 17.75%; }
    .k2s2{ left: 50%; top: 43.39%; width: 50%; height: 17.75%; }
    .k2s1{ left: 50%; top: 61.15%; width: 50%; height: 17.75%; }

    /* Gallery */
    .galleryGrid{
      display:grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .galleryItem{
      border-radius: var(--radius);
      overflow:hidden;
      border: 1px solid var(--border);
      box-shadow: 0 14px 40px rgba(16,24,40,.10);
      background:#fff;
      cursor: pointer;
    }
    .galleryItem img{
      width:100%;
      height:auto;
      display:block;
      object-fit: contain;
      background:#fff;
    }

    /* symmetric on desktop */
    @media (min-width: 960px){
      .galleryItem{
        aspect-ratio: 4 / 3;
        display:flex;
        align-items:center;
        justify-content:center;
      }
      .galleryItem img{
        width:100%;
        height:100%;
        object-fit: cover;
      }
    }

    /* Lightbox */
    .lightbox{
      position:fixed; inset:0;
      background: rgba(0,0,0,.84);
      display:none;
      align-items:center;
      justify-content:center;
      padding: 10px;
      z-index: 99;
    }
    .lightbox.open{ display:flex; }
    .lbPanel{
      width: 100%;
      height: 86vh;
      max-width: 980px;
      background:#0f1115;
      border-radius: 16px;
      overflow:hidden;
      border: 1px solid rgba(255,255,255,.10);
      position:relative;
    }
    .lbTop{
      position:absolute; top:0; left:0; right:0;
      display:flex; justify-content:space-between; align-items:center;
      padding: 10px; z-index:2; gap:10px;
      background: linear-gradient(180deg, rgba(0,0,0,.58), rgba(0,0,0,0));
    }
    .lbTitle{ color: rgba(255,255,255,.86); font-size: 12px; font-weight: 950; }
    .lbBtns{ display:flex; gap:8px; }
    .iconBtn{
      width: 42px; height: 42px;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,.18);
      background: rgba(255,255,255,.08);
      color:#fff;
      cursor:pointer;
      display:inline-flex; align-items:center; justify-content:center;
      font-size: 16px; font-weight: 900;
    }
    .lbStage{ width:100%; height:100%; display:flex; align-items:center; justify-content:center; overflow:hidden; touch-action: pan-y; }
    .lbImg{ max-width: 96%; max-height: 90%; user-select:none; -webkit-user-drag:none; }
    .lbHint{
      position:absolute; bottom: 10px; left: 10px; right: 10px;
      text-align:center; color: rgba(255,255,255,.72); font-size: 12px; pointer-events:none;
    }

    /* Modal details (stan) */
    .backdrop{
      position:fixed; inset:0;
      background: rgba(16,24,40,.45);
      display:none;
      align-items:center;
      justify-content:center;
      padding: 12px;
      z-index: 90;
    }
    .backdrop.open{ display:flex; }

    .modal{
      width: 100%;
      max-width: 980px;
      max-height: 90vh;
      overflow:auto;
      background:#fff;
      border: 1px solid var(--border);
      border-radius: 16px;
      box-shadow: 0 30px 90px rgba(16,24,40,.25);
    }
    @media (max-width: 720px){
      .modal{
        height: 94vh;
        max-height: 94vh;
        border-radius: 18px;
      }
    }

    .modalHeader{
      position: sticky;
      top:0;
      background: rgba(255,255,255,.94);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      padding: 12px;
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:10px;
    }
    .modalHeader h2{ margin:0; font-size: 15px; font-weight: 950; }
    .modalHeader .meta{ margin-top: 4px; color: var(--muted); font-size: 12px; }
    .closeBtn{
      width: 40px; height: 40px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background:#fff;
      box-shadow: 0 10px 22px rgba(16,24,40,.06);
      cursor:pointer;
      font-size: 18px;
      font-weight: 950;
    }
    .modalBody{
      padding: 12px;
      display:grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .badge{
      font-size: 12px;
      font-weight: 950;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: rgba(246,247,251,.7);
      color: var(--muted);
      white-space: nowrap;
    }
    .badge.sold{
      color:#fff;
      border-color: rgba(255,255,255,.25);
      background: linear-gradient(135deg, var(--danger2), var(--danger));
    }

    table{ width:100%; border-collapse:collapse; font-size: 13px; }
    th,td{ padding: 10px; border-bottom: 1px solid var(--border); text-align:left; vertical-align:top; }
    th{ color: var(--muted); text-transform:uppercase; letter-spacing:.06em; font-size: 12px; background: rgba(246,247,251,.65); }

    .thumb{
      width:100%;
      border-radius: 14px;
      border: 1px solid var(--border);
      box-shadow: 0 10px 26px rgba(16,24,40,.06);
      display:block;
      cursor: zoom-in;
      background:#fff;
    }

    /* Floorplan viewer */
    .viewerBack{
      position:fixed;
      inset:0;
      background: rgba(16,24,40,.68);
      display:none;
      align-items:center;
      justify-content:center;
      padding: 10px;
      z-index: 95;
    }
    .viewerBack.open{ display:flex; }
    .viewer{
      width: 100%;
      height: min(90vh, 860px);
      background:#0b1220;
      border-radius: 16px;
      overflow:hidden;
      border: 1px solid rgba(255,255,255,.12);
      box-shadow: 0 30px 90px rgba(0,0,0,.45);
      display:flex;
      flex-direction:column;
    }
    .viewerTop{
      padding: 10px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:8px;
      color:#fff;
      background: rgba(255,255,255,.06);
      border-bottom: 1px solid rgba(255,255,255,.10);
      font-weight: 950;
      font-size: 13px;
    }
    .viewerBtns{ display:flex; gap:8px; flex-wrap:wrap; }
    .vbtn{
      border: 1px solid rgba(255,255,255,.16);
      background: rgba(255,255,255,.08);
      color:#fff;
      padding: 8px 10px;
      border-radius: 14px;
      cursor:pointer;
      font-weight: 950;
      font-size: 12px;
    }
    .stage{
      position:relative;
      flex:1;
      overflow:hidden;
      touch-action:none;
    }
    .stage img{
      position:absolute;
      top:50%; left:50%;
      transform: translate(-50%,-50%);
      transform-origin:center center;
      user-select:none;
      -webkit-user-drag:none;
      max-width:none;
    }

    /* Form */
    form{
      max-width: 900px;
      margin: 0 auto;
      background: rgba(255,255,255,.95);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: 0 14px 40px rgba(16,24,40,.10);
      padding: 14px;
    }
    label{
      display:block;
      font-size: 12px;
      color: var(--muted);
      margin: 0 0 6px 2px;
      font-weight: 950;
    }
    input,select,textarea{
      width:100%;
      padding: 12px;
      border: 1px solid rgba(0,0,0,.15);
      border-radius: 14px;
      outline:none;
      font-size: 14px;
      background:#fff;
    }
    textarea{ min-height: 120px; resize: vertical; }
    .formGrid{ display:grid; grid-template-columns: 1fr; gap: 12px; }

    .payRow{ display:flex; flex-direction:column; gap:10px; margin-top: 6px; }
    .payOpt{
      display:flex;
      gap:10px;
      align-items:flex-start;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 12px;
      background: rgba(246,247,251,.7);
    }
    .payOpt input{ width:auto; margin-top: 3px; }
    .payOpt b{ display:block; }
    .payOpt span{ display:none; }

    .formNote{ text-align:center; color: var(--muted); font-size: 12px; margin-top: 10px; }

    /* Map */
    .mapWrap{
      overflow:hidden;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      box-shadow: 0 14px 40px rgba(16,24,40,.10);
      background: rgba(255,255,255,.95);
    }
    iframe{ width:100%; height: 320px; border:0; display:block; }

    /* Footer */
    footer{
      padding: 34px 0;
      border-top: 1px solid var(--border);
      background: rgba(255,255,255,.95);
    }
    .footerGrid{ display:grid; grid-template-columns: 1fr; gap: 12px; }
    .footerTitle{ font-weight: 950; margin-bottom: 8px; }
    .footerMuted{ color: var(--muted); font-size: 13px; line-height:1.7; }
    .footerLinks a{
      display:block;
      padding: 6px 0;
      color: var(--muted);
      font-size: 13px;
      text-decoration:none;
      font-weight: 900;
    }
    .footerLinks a:hover{ color: var(--text); }
    .footerBottom{
      margin-top: 12px;
      padding-top: 12px;
      border-top: 1px solid var(--border);
      color: var(--muted);
      font-size: 12px;
      line-height:1.6;
    }

    .toast{
      position:fixed;
      left:50%;
      bottom:18px;
      transform: translateX(-50%);
      background: rgba(16,24,40,.92);
      color:#fff;
      padding: 10px 12px;
      border-radius: 999px;
      font-weight: 950;
      font-size: 13px;
      box-shadow: 0 18px 46px rgba(0,0,0,.30);
      display:none;
      z-index: 120;
    }
    .toast.show{ display:block; }

    @media (min-width: 960px){
      .introTitle{ font-size: 34px; }
      .sectionTitle{ font-size: 28px; }
      .grid{ grid-template-columns: 1fr 1fr; gap: 14px; }
      .galleryGrid{ grid-template-columns: repeat(3, 1fr); }
      iframe{ height: 460px; }
      .formGrid{ grid-template-columns: 1fr 1fr; }
      .footerGrid{ grid-template-columns: 2fr 1fr 1fr; gap: 16px; }
      .tag{ font-size: 12px; padding: 6px 9px; top:auto; bottom:10px; }
      .tag.left{ left:10px; }
